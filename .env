# Environment variables for TechnovaQuest
# Add your API keys here and restart the development server.

# Primary Google Gemini API key for backend-only use
# The frontend calls a local backend route, so the key should not be exposed in browser code.
GOOGLE_GEMINI_API_KEY=AIzaSyA5de4ULzR6T8TOMKSGy-SYKCHCSbt6WGc

# Optional Google Gemini API endpoint for backend use.
# Leave empty to use the default Google Generative Language endpoint.
GOOGLE_GEMINI_API_URL=

# Default Gemini model to use for explanations.
GOOGLE_GEMINI_MODEL=gemini-3-flash-preview

# Backend URL for the AI server. Keep it local in development.
VITE_AI_BACKEND_URL=http://localhost:3001

# Secondary Grok API key.
# This will be used only if Gemini is unavailable.
VITE_GROK_API_KEY=

# Optional Grok API endpoint.
# Leave empty to use the default OpenAI-compatible endpoint.
VITE_GROK_API_URL=
VITE_GROK_MODEL=grok-1

# Optional tertiary OpenAI API key fallback.
VITE_OPENAI_API_KEY=

# Optional OpenAI API endpoint.
# Leave empty to use the default OpenAI-compatible endpoint.
VITE_OPENAI_API_URL=
VITE_OPENAI_MODEL=gpt-4o-mini
